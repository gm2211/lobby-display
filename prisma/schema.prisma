generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public"]
}

model Service {
  id                Int                @id @default(autoincrement())
  name              String
  status            String             @default("Operational")
  notes             String             @default("")
  lastChecked       DateTime           @default(now())
  sortOrder         Int                @default(0)
  markedForDeletion Boolean            @default(false)
  deletedAt         DateTime?
  statusLogs        ServiceStatusLog[]

  @@schema("public")
}

model ServiceStatusLog {
  id        Int      @id @default(autoincrement())
  serviceId Int
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  status    String
  timestamp DateTime @default(now())

  @@schema("public")
}

model Event {
  id                Int       @id @default(autoincrement())
  title             String
  subtitle          String    @default("")
  details           String    @default("[]")
  imageUrl          String    @default("")
  accentColor       String    @default("")
  sortOrder         Int       @default(0)
  markedForDeletion Boolean   @default(false)
  deletedAt         DateTime?

  @@schema("public")
}

model Advisory {
  id                Int       @id @default(autoincrement())
  message           String
  active            Boolean   @default(true)
  markedForDeletion Boolean   @default(false)
  deletedAt         DateTime?

  @@schema("public")
}

model BuildingConfig {
  id                   Int    @id @default(autoincrement())
  dashboardTitle       String @default("Building Updates")
  scrollSpeed          Int    @default(30)
  tickerSpeed          Int    @default(25)
  servicesScrollSpeed  Int    @default(8)
  servicesFontSize     Int    @default(18)
  notesFontSize        Int    @default(18)
  notesFontWeight      Int    @default(700)

  @@schema("public")
}

model PublishedSnapshot {
  id          Int      @id @default(autoincrement())
  version     Int      @unique
  data        String
  publishedAt DateTime @default(now())
  publishedBy String   @default("admin")

  @@schema("public")
}

enum Role {
  VIEWER
  EDITOR
  ADMIN

  @@schema("public")
}

model User {
  id                Int       @id @default(autoincrement())
  username          String    @unique
  passwordHash      String
  role              Role      @default(EDITOR)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  displayName       String?
  phone             String?
  emergencyContact  String?
  unitNumber        String?
  unitFloor         String?
  notificationPrefs String?
  sentMessages      Message[] @relation("sentMessages")
  receivedMessages  Message[] @relation("receivedMessages")

  @@schema("public")
}

model Session {
  id        String   @id
  data      String
  expiresAt DateTime

  @@schema("public")
}

model Message {
  id          String    @id @default(uuid())
  senderId    Int
  sender      User      @relation("sentMessages", fields: [senderId], references: [id])
  recipientId Int
  recipient   User      @relation("receivedMessages", fields: [recipientId], references: [id])
  subject     String?
  body        String
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  @@schema("public")
}
