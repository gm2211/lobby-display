generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "platform"]
}

model Service {
  id                Int                @id @default(autoincrement())
  name              String
  status            String             @default("Operational")
  notes             String             @default("")
  lastChecked       DateTime           @default(now())
  sortOrder         Int                @default(0)
  markedForDeletion Boolean            @default(false)
  deletedAt         DateTime?
  statusLogs        ServiceStatusLog[]

  @@schema("public")
}

model ServiceStatusLog {
  id        Int      @id @default(autoincrement())
  serviceId Int
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  status    String
  timestamp DateTime @default(now())

  @@schema("public")
}

model Event {
  id                Int       @id @default(autoincrement())
  title             String
  subtitle          String    @default("")
  details           String    @default("[]")
  imageUrl          String    @default("")
  accentColor       String    @default("")
  sortOrder         Int       @default(0)
  markedForDeletion Boolean   @default(false)
  deletedAt         DateTime?

  @@schema("public")
}

model Advisory {
  id                Int       @id @default(autoincrement())
  message           String
  active            Boolean   @default(true)
  markedForDeletion Boolean   @default(false)
  deletedAt         DateTime?

  @@schema("public")
}

model BuildingConfig {
  id                   Int    @id @default(autoincrement())
  dashboardTitle       String @default("Building Updates")
  scrollSpeed          Int    @default(30)
  tickerSpeed          Int    @default(25)
  servicesScrollSpeed  Int    @default(8)
  servicesFontSize     Int    @default(18)
  notesFontSize        Int    @default(18)
  notesFontWeight      Int    @default(700)

  @@schema("public")
}

model PublishedSnapshot {
  id          Int      @id @default(autoincrement())
  version     Int      @unique
  data        String
  publishedAt DateTime @default(now())
  publishedBy String   @default("admin")

  @@schema("public")
}

enum Role {
  VIEWER
  EDITOR
  ADMIN

  @@schema("public")
}

model User {
  id                Int           @id @default(autoincrement())
  username          String        @unique
  passwordHash      String
  role              Role          @default(EDITOR)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  displayName       String?
  phone             String?
  emergencyContact  String?
  unitNumber        String?
  unitFloor         String?
  notificationPrefs String?
  platformUser      PlatformUser?
  sentMessages      Message[]     @relation("sentMessages")
  receivedMessages  Message[]     @relation("receivedMessages")

  @@schema("public")
}

model Session {
  id        String   @id
  data      String
  expiresAt DateTime

  @@schema("public")
}

// ---------------------------------------------------------------------------
// Platform schema models
// ---------------------------------------------------------------------------

enum PlatformRole {
  RESIDENT
  BOARD_MEMBER
  MANAGER
  SECURITY
  CONCIERGE

  @@schema("platform")
}

model PlatformUser {
  id                  String               @id @default(uuid())
  userId              Int                  @unique
  user                User                 @relation(fields: [userId], references: [id])
  unitNumber          String?
  role                PlatformRole         @default(RESIDENT)
  phone               String?
  moveInDate          DateTime?
  emergencyContact    Json?
  preferences         Json?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  announcements       Announcement[]
  uploads             Upload[]
  maintenanceComments MaintenanceComment[] @relation("MaintenanceComments")
  bookings            Booking[]
  visitors            Visitor[]            @relation("VisitorHost")
  visitorLogs         VisitorLog[]         @relation("VisitorLogPerformer")
  createdEvents       PlatformEvent[]      @relation("EventCreator")
  eventRsvps          EventRSVP[]          @relation("EventRSVPs")
  violations          Violation[]          @relation("ViolationReporter")
  violationComments   ViolationComment[]   @relation("ViolationComments")
  payments            Payment[]            @relation("Payments")
  trainingCompletions TrainingCompletion[]
  createdConsentForms ConsentForm[]        @relation("ConsentFormCreator")
  consentSignatures   ConsentSignature[]
  createdSurveys      Survey[]             @relation("SurveyCreator")
  surveyResponses     SurveyResponse[]     @relation("SurveyResponses")
  uploadedDocuments   Document[]           @relation("DocumentUploader")
  directoryEntry      DirectoryEntry?      @relation("DirectoryEntry")
  announcementReads   AnnouncementRead[]   @relation("AnnouncementReads")
  forumThreads        ForumThread[]        @relation("ForumThreads")
  forumPosts          ForumPost[]          @relation("ForumPosts")
  marketplaceListings MarketplaceListing[] @relation("MarketplaceListings")
  chatSessions        ChatSession[]        @relation("ChatSessions")
  postUpvotes         PostUpvote[]         @relation("PostUpvotes")

  @@schema("platform")
}

enum MaintenanceStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  CLOSED

  @@schema("platform")
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  URGENT

  @@schema("platform")
}

model MaintenanceRequest {
  id                String              @id @default(uuid())
  title             String
  description       String
  category          String
  status            MaintenanceStatus
  priority          MaintenancePriority
  unitNumber        String
  reportedBy        String
  assignedTo        String?
  resolvedAt        DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  markedForDeletion Boolean             @default(false)
  comments          MaintenanceComment[]
  photos            MaintenancePhoto[]

  @@schema("platform")
}

model MaintenanceComment {
  id         String             @id @default(uuid())
  requestId  String
  request    MaintenanceRequest @relation(fields: [requestId], references: [id])
  authorId   String
  author     PlatformUser       @relation("MaintenanceComments", fields: [authorId], references: [id])
  body       String
  isInternal Boolean            @default(false)
  createdAt  DateTime           @default(now())

  @@schema("platform")
}

model MaintenancePhoto {
  id        String             @id @default(uuid())
  requestId String
  request   MaintenanceRequest @relation(fields: [requestId], references: [id])
  uploadId  String
  upload    Upload             @relation(fields: [uploadId], references: [id])
  caption   String?
  createdAt DateTime           @default(now())

  @@schema("platform")
}

model Announcement {
  id                String       @id @default(uuid())
  title             String
  body              String
  pinned            Boolean      @default(false)
  priority          Int          @default(0)
  publishedAt       DateTime?
  expiresAt         DateTime?
  createdBy         String
  createdByUser     PlatformUser @relation(fields: [createdBy], references: [id])
  buildingId        String?
  markedForDeletion Boolean      @default(false)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  reads             AnnouncementRead[]

  @@schema("platform")
}

// ---------------------------------------------------------------------------
// Amenity booking models
// ---------------------------------------------------------------------------

enum AmenityRuleType {
  MAX_BOOKINGS_PER_DAY
  MAX_BOOKINGS_PER_WEEK
  BLACKOUT_DATE
  ROLE_RESTRICTION
  CUSTOM

  @@schema("platform")
}

model Amenity {
  id                String    @id @default(uuid())
  name              String
  description       String
  location          String?
  capacity          Int?
  requiresApproval  Boolean   @default(false)
  pricePerHour      Decimal?
  currency          String    @default("USD")
  availableFrom     String
  availableTo       String
  daysAvailable     Int[]
  minAdvanceHours   Int       @default(0)
  maxAdvanceHours   Int       @default(720)
  maxDurationHours  Int       @default(4)
  active            Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  rules             AmenityRule[]
  images            AmenityImage[]
  bookings          Booking[]

  @@schema("platform")
}

model AmenityRule {
  id         String          @id @default(uuid())
  amenityId  String
  amenity    Amenity         @relation(fields: [amenityId], references: [id])
  ruleType   AmenityRuleType
  ruleValue  Json
  active     Boolean         @default(true)

  @@schema("platform")
}

model AmenityImage {
  id         String  @id @default(uuid())
  amenityId  String
  amenity    Amenity @relation(fields: [amenityId], references: [id])
  uploadId   String
  sortOrder  Int

  @@schema("platform")
}

// ---------------------------------------------------------------------------
// Parcel tracking models
// ---------------------------------------------------------------------------

enum ParcelStatus {
  RECEIVED
  NOTIFIED
  PICKED_UP

  @@schema("platform")
}

model Parcel {
  id                String       @id @default(uuid())
  trackingNumber    String?
  carrier           String?
  description       String
  recipientId       String
  unitNumber        String
  status            ParcelStatus @default(RECEIVED)
  receivedBy        String
  receivedAt        DateTime     @default(now())
  pickedUpAt        DateTime?
  photoId           String?
  notes             String?
  markedForDeletion Boolean      @default(false)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@schema("platform")
}

// ---------------------------------------------------------------------------
// Platform settings & uploads
// ---------------------------------------------------------------------------

model PlatformSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt

  @@schema("platform")
}

model Upload {
  id                String             @id @default(uuid())
  filename          String
  mimeType          String
  size              Int
  storagePath       String
  uploadedBy        String
  uploadedByUser    PlatformUser       @relation(fields: [uploadedBy], references: [id])
  createdAt         DateTime           @default(now())
  maintenancePhotos MaintenancePhoto[]
  trainingResources TrainingResource[]

  @@schema("platform")
}

// ---------------------------------------------------------------------------
// Booking models
// ---------------------------------------------------------------------------

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  COMPLETED
  WAITLISTED

  @@schema("platform")
}

model Booking {
  id                 String          @id @default(uuid())
  amenityId          String
  amenity            Amenity         @relation(fields: [amenityId], references: [id])
  userId             String
  user               PlatformUser    @relation(fields: [userId], references: [id])
  startTime          DateTime
  endTime            DateTime
  status             BookingStatus   @default(PENDING)
  notes              String?
  approvedBy         String?
  approvedAt         DateTime?
  cancellationReason String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  payment            BookingPayment?

  @@schema("platform")
}

enum BookingPaymentStatus {
  PENDING
  PAID
  REFUNDED

  @@schema("platform")
}

model BookingPayment {
  id         String               @id @default(uuid())
  bookingId  String               @unique
  booking    Booking              @relation(fields: [bookingId], references: [id])
  amount     Decimal
  status     BookingPaymentStatus @default(PENDING)
  paidAt     DateTime?
  refundedAt DateTime?

  @@schema("platform")
}

// ---------------------------------------------------------------------------
// Visitor management models
// ---------------------------------------------------------------------------

enum VisitorStatus {
  EXPECTED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED

  @@schema("platform")
}

enum VisitorAction {
  CHECK_IN
  CHECK_OUT

  @@schema("platform")
}

model Visitor {
  id           String        @id @default(uuid())
  hostId       String
  host         PlatformUser  @relation("VisitorHost", fields: [hostId], references: [id])
  guestName    String
  guestEmail   String?
  guestPhone   String?
  purpose      String?
  expectedDate DateTime
  accessCode   String        @unique
  status       VisitorStatus @default(EXPECTED)
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  logs         VisitorLog[]

  @@schema("platform")
}

model VisitorLog {
  id          String        @id @default(uuid())
  visitorId   String
  visitor     Visitor       @relation(fields: [visitorId], references: [id])
  action      VisitorAction
  performedBy String
  performer   PlatformUser  @relation("VisitorLogPerformer", fields: [performedBy], references: [id])
  timestamp   DateTime      @default(now())
  notes       String?

  @@schema("platform")
}

// ---------------------------------------------------------------------------
// Event models
// ---------------------------------------------------------------------------

enum RSVPStatus {
  GOING
  MAYBE
  NOT_GOING

  @@schema("platform")
}

model PlatformEvent {
  id             String       @id @default(uuid())
  title          String
  description    String
  location       String?
  startTime      DateTime
  endTime        DateTime?
  isRecurring    Boolean      @default(false)
  recurrenceRule String?
  capacity       Int?
  imageId        String?
  createdBy      String
  creator        PlatformUser @relation("EventCreator", fields: [createdBy], references: [id])
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  rsvps          EventRSVP[]

  @@schema("platform")
}

model EventRSVP {
  id        String        @id @default(uuid())
  eventId   String
  event     PlatformEvent @relation(fields: [eventId], references: [id])
  userId    String
  user      PlatformUser  @relation("EventRSVPs", fields: [userId], references: [id])
  status    RSVPStatus
  createdAt DateTime      @default(now())

  @@unique([eventId, userId])
  @@schema("platform")
}

// ---------------------------------------------------------------------------
// Violation models
// ---------------------------------------------------------------------------

enum ViolationStatus {
  REPORTED
  UNDER_REVIEW
  CONFIRMED
  APPEALED
  RESOLVED
  DISMISSED

  @@schema("platform")
}

enum ViolationSeverity {
  LOW
  MEDIUM
  HIGH

  @@schema("platform")
}

model Violation {
  id           String            @id @default(uuid())
  reportedBy   String
  reporter     PlatformUser      @relation("ViolationReporter", fields: [reportedBy], references: [id])
  unitNumber   String
  category     String
  description  String
  evidence     Json?
  status       ViolationStatus   @default(REPORTED)
  severity     ViolationSeverity
  fineAmount   Decimal?
  assignedTo   String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  comments     ViolationComment[]
  paymentItems PaymentItem[]     @relation("ViolationPaymentItems")

  @@schema("platform")
}

model ViolationComment {
  id          String       @id @default(uuid())
  violationId String
  violation   Violation    @relation(fields: [violationId], references: [id])
  authorId    String
  author      PlatformUser @relation("ViolationComments", fields: [authorId], references: [id])
  body        String
  isInternal  Boolean      @default(false)
  createdAt   DateTime     @default(now())

  @@schema("platform")
}

// ---------------------------------------------------------------------------
// Payment models
// ---------------------------------------------------------------------------

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED

  @@schema("platform")
}

model Payment {
  id            String        @id @default(uuid())
  userId        String
  user          PlatformUser  @relation("Payments", fields: [userId], references: [id])
  amount        Decimal
  currency      String        @default("USD")
  status        PaymentStatus @default(PENDING)
  paymentMethod String?
  externalId    String?
  description   String
  dueDate       DateTime?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  items         PaymentItem[]

  @@schema("platform")
}

model PaymentItem {
  id          String     @id @default(uuid())
  paymentId   String
  payment     Payment    @relation(fields: [paymentId], references: [id])
  violationId String?
  violation   Violation? @relation("ViolationPaymentItems", fields: [violationId], references: [id])
  description String
  amount      Decimal
  category    String

  @@schema("platform")
}

// ---------------------------------------------------------------------------
// Training models
// ---------------------------------------------------------------------------

enum ContentType {
  VIDEO
  DOCUMENT
  LINK

  @@schema("platform")
}

model TrainingResource {
  id               String               @id @default(uuid())
  title            String
  description      String
  contentType      ContentType
  contentUrl       String?
  uploadId         String?
  upload           Upload?              @relation(fields: [uploadId], references: [id])
  requiredForRoles PlatformRole[]
  dueDate          DateTime?
  sortOrder        Int                  @default(0)
  active           Boolean              @default(true)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  completions      TrainingCompletion[]

  @@schema("platform")
}

model TrainingCompletion {
  id          String           @id @default(uuid())
  resourceId  String
  resource    TrainingResource @relation(fields: [resourceId], references: [id])
  userId      String
  user        PlatformUser     @relation(fields: [userId], references: [id])
  completedAt DateTime         @default(now())

  @@unique([resourceId, userId])
  @@schema("platform")
}

// ---------------------------------------------------------------------------
// Consent models
// ---------------------------------------------------------------------------

model ConsentForm {
  id               String             @id @default(uuid())
  title            String
  body             String
  version          Int
  requiredForRoles PlatformRole[]
  active           Boolean            @default(true)
  createdBy        String
  creator          PlatformUser       @relation("ConsentFormCreator", fields: [createdBy], references: [id])
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  signatures       ConsentSignature[]

  @@schema("platform")
}

model ConsentSignature {
  id        String       @id @default(uuid())
  formId    String
  form      ConsentForm  @relation(fields: [formId], references: [id])
  userId    String
  user      PlatformUser @relation(fields: [userId], references: [id])
  signedAt  DateTime     @default(now())
  ipAddress String?
  userAgent String?

  @@unique([formId, userId])
  @@schema("platform")
}

// ---------------------------------------------------------------------------
// Search index model
// ---------------------------------------------------------------------------

model SearchIndex {
  id         String   @id @default(uuid())
  entityType String
  entityId   String
  title      String
  body       String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@unique([entityType, entityId])
  @@schema("platform")
}

// ---------------------------------------------------------------------------
// Survey models
// ---------------------------------------------------------------------------

model Survey {
  id          String           @id @default(uuid())
  title       String
  description String
  active      Boolean          @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  createdBy   String
  creator     PlatformUser     @relation("SurveyCreator", fields: [createdBy], references: [id])
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  questions   SurveyQuestion[]
  responses   SurveyResponse[]

  @@schema("platform")
}

model SurveyQuestion {
  id        String  @id @default(uuid())
  surveyId  String
  survey    Survey  @relation(fields: [surveyId], references: [id])
  text      String
  type      String
  options   Json?
  required  Boolean @default(true)
  sortOrder Int     @default(0)

  @@schema("platform")
}

model SurveyResponse {
  id        String       @id @default(uuid())
  surveyId  String
  survey    Survey       @relation(fields: [surveyId], references: [id])
  userId    String
  user      PlatformUser @relation("SurveyResponses", fields: [userId], references: [id])
  answers   Json
  createdAt DateTime     @default(now())

  @@schema("platform")
}

// ---------------------------------------------------------------------------
// Document management models
// ---------------------------------------------------------------------------

model DocumentCategory {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  sortOrder   Int        @default(0)
  documents   Document[]

  @@schema("platform")
}

model Document {
  id          String            @id @default(uuid())
  title       String
  description String?
  categoryId  String
  category    DocumentCategory  @relation(fields: [categoryId], references: [id])
  uploadedBy  String
  uploader    PlatformUser      @relation("DocumentUploader", fields: [uploadedBy], references: [id])
  active      Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  versions    DocumentVersion[]

  @@schema("platform")
}

model DocumentVersion {
  id          String   @id @default(uuid())
  documentId  String
  document    Document @relation(fields: [documentId], references: [id])
  version     Int
  filename    String
  mimeType    String
  size        Int
  storagePath String
  uploadedBy  String
  createdAt   DateTime @default(now())

  @@unique([documentId, version])
  @@schema("platform")
}

// ---------------------------------------------------------------------------
// Directory models
// ---------------------------------------------------------------------------

model DirectoryEntry {
  id          String       @id @default(uuid())
  userId      String       @unique
  user        PlatformUser @relation("DirectoryEntry", fields: [userId], references: [id])
  displayName String
  title       String?
  department  String?
  phone       String?
  email       String?
  photoUrl    String?
  visible     Boolean      @default(true)
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@schema("platform")
}

// ---------------------------------------------------------------------------
// Announcement read tracking
// ---------------------------------------------------------------------------

model AnnouncementRead {
  id             String       @id @default(uuid())
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id])
  userId         String
  user           PlatformUser @relation("AnnouncementReads", fields: [userId], references: [id])
  readAt         DateTime     @default(now())

  @@unique([announcementId, userId])
  @@schema("platform")
}

// ---------------------------------------------------------------------------
// Forum models
// ---------------------------------------------------------------------------

model ForumCategory {
  id          String        @id @default(uuid())
  name        String        @unique
  description String?
  sortOrder   Int           @default(0)
  threads     ForumThread[]

  @@schema("platform")
}

model ForumThread {
  id         String        @id @default(uuid())
  categoryId String
  category   ForumCategory @relation(fields: [categoryId], references: [id])
  title      String
  authorId   String
  author     PlatformUser  @relation("ForumThreads", fields: [authorId], references: [id])
  pinned     Boolean       @default(false)
  locked     Boolean       @default(false)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  posts      ForumPost[]

  @@schema("platform")
}

model ForumPost {
  id        String       @id @default(uuid())
  threadId  String
  thread    ForumThread  @relation(fields: [threadId], references: [id])
  authorId  String
  author    PlatformUser @relation("ForumPosts", fields: [authorId], references: [id])
  body      String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  upvotes   PostUpvote[] @relation("PostUpvotes")

  @@schema("platform")
}

// ---------------------------------------------------------------------------
// Marketplace models
// ---------------------------------------------------------------------------

enum ListingStatus {
  ACTIVE
  SOLD
  EXPIRED
  REMOVED

  @@schema("platform")
}

model MarketplaceListing {
  id          String        @id @default(uuid())
  sellerId    String
  seller      PlatformUser  @relation("MarketplaceListings", fields: [sellerId], references: [id])
  title       String
  description String
  price       Decimal?
  category    String
  condition   String?
  status      ListingStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  images      ListingImage[]

  @@schema("platform")
}

model ListingImage {
  id        String              @id @default(uuid())
  listingId String
  listing   MarketplaceListing  @relation(fields: [listingId], references: [id])
  url       String
  sortOrder Int                 @default(0)

  @@schema("platform")
}

// ---------------------------------------------------------------------------
// Chat models
// ---------------------------------------------------------------------------

enum ChatRole {
  USER
  ASSISTANT
  SYSTEM

  @@schema("platform")
}

model ChatSession {
  id        String        @id @default(uuid())
  userId    String
  user      PlatformUser  @relation("ChatSessions", fields: [userId], references: [id])
  title     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]

  @@schema("platform")
}

model ChatMessage {
  id        String      @id @default(uuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id])
  role      ChatRole
  content   String
  metadata  Json?
  createdAt DateTime    @default(now())

  @@schema("platform")
}

// ---------------------------------------------------------------------------
// Forum upvote tracking
// ---------------------------------------------------------------------------

model PostUpvote {
  id        String       @id @default(uuid())
  postId    String
  post      ForumPost    @relation("PostUpvotes", fields: [postId], references: [id])
  userId    String
  user      PlatformUser @relation("PostUpvotes", fields: [userId], references: [id])
  createdAt DateTime     @default(now())

  @@unique([postId, userId])
  @@schema("platform")
}

model Message {
  id          String    @id @default(uuid())
  senderId    Int
  sender      User      @relation("sentMessages", fields: [senderId], references: [id])
  recipientId Int
  recipient   User      @relation("receivedMessages", fields: [recipientId], references: [id])
  subject     String?
  body        String
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  @@schema("public")
}

