{
  "name": "lobby-display",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "prisma generate && prisma db push && tsx watch server/index.ts",
    "build": "prisma generate && prisma db push && vite build && npm run build:server",
    "build:server": "esbuild server/index.ts --bundle --platform=node --format=esm --outdir=dist-server --packages=external",
    "start": "NODE_ENV=production node dist-server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test --config=e2e/playwright.config.ts",
    "e2e:local": "E2E_BASE_URL=http://localhost:3000 playwright test --config=e2e/playwright.config.ts",
    "e2e:staging": "E2E_BASE_URL=https://seven7-hudson-staging.onrender.com playwright test --config=e2e/playwright.config.ts",
    "e2e:report": "playwright show-report e2e/playwright-report",
    "test:user:create": "tsx scripts/test-user.ts create",
    "test:user:delete": "tsx scripts/test-user.ts delete",
    "screenshot:compare": "tsx scripts/screenshot-compare.ts"
  },
  "dependencies": {
    "@fastify/express": "^4.0.4",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "esbuild-wasm": "^0.25.0",
    "express": "^4.21.0",
    "express-session": "^1.19.0",
    "fastify": "^5.8.2",
    "lucide-react": "^0.577.0",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.2",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.2.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/supertest": "^6.0.3",
    "@vitejs/plugin-react": "^4.3.0",
    "esbuild": "^0.25.0",
    "jsdom": "^28.0.0",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "~5.6.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.18"
  }
}
